{
  "name": "telecareer-talent-matching",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run sync:media && next dev",
    "demo": "npm run sync:media && next dev",
    "sync:media": "mkdir -p public/img/media && cp -rn wordpress/engine/assets/img/media/. public/img/media/ 2>/dev/null || true",
    "build": "npm run sync:media && next build && npm run build:standalone-assets",
    "build:standalone-assets": "cp -r .next/static .next/standalone/.next/static && cp -r public .next/standalone/public && mkdir -p .next/standalone/wordpress/seed && cp -r wordpress/seed .next/standalone/wordpress/",
    "start": "cd .next/standalone && node server.js",
    "lint": "next lint",
    "docker:demo": "docker compose up --build",
    "docker:demo:detach": "docker compose up --build -d",
    "wp:start": "DOCKER_BUILDKIT=0 COMPOSE_DOCKER_CLI_BUILD=0 wp-env start",
    "wp:stop": "wp-env stop",
    "wp:destroy": "wp-env destroy",
    "theme:build": "tailwindcss -c wordpress/engine/tailwind.config.js -i wordpress/engine/src/input.css -o wordpress/engine/assets/css/main.css --minify",
    "theme:watch": "tailwindcss -c wordpress/engine/tailwind.config.js -i wordpress/engine/src/input.css -o wordpress/engine/assets/css/main.css --watch"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.47.10",
    "next": "14.2.18",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@wordpress/env": "^11.8.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5"
  }
}
